# --- Required for the LLM (free) ---
# Get a key at https://console.groq.com
GROQ_API_KEY=gsk_...

# --- Required for owner-only cloud features (Phase 6+) ---
# Pick a strong password (min 8 chars). Used to sign in at /login.
JOA_OWNER_SECRET=

# --- Required if you provisioned Vercel KV ---
# `vercel env pull .env.local` will populate these automatically after you
# add the Vercel KV integration in the project dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Optional, only needed when you wire Phase 6 M1+ ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: https://<your-app>/api/google/callback (and the localhost variant)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (free 100 mails/day) for the weekly digest. Phase 6 M4.
RESEND_API_KEY=
# Required by Vercel Cron when running the digest:
CRON_SECRET=
